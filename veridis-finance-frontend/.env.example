# Backend service URL (veridis-finance API)
VERIDIS_API_URL=http://localhost:4000

# Used by Next.js middleware to verify JWT cookie signature.
# If omitted, middleware validates token presence only.
JWT_SECRET=replace-with-the-same-secret-used-in-backend

# Active notification adapter in UI.
# Allowed values: sonner | hot-toast | sileo | toastify
NEXT_PUBLIC_NOTIFICATION_LIBRARY=sonner
