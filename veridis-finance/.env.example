NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=8h

# Future tenant routing domain (e.g. finance.veridis.app)
APP_BASE_DOMAIN=finance.veridis.642studio.com

AUTOMATION_RATE_LIMIT_MAX=60
AUTOMATION_RATE_LIMIT_WINDOW_MS=60000
INVOICE_XML_MAX_FILE_SIZE_BYTES=1048576
BANK_STATEMENT_PDF_MAX_FILE_SIZE_BYTES=8388608

# AI provider encryption key (required for finance.ai_providers)
AI_MASTER_KEY=replace-with-a-strong-32+char-secret

# Optional system-level provider fallback (used when org has no active AI provider)
# AI_SYSTEM_PROVIDER=openai
# AI_SYSTEM_OPENAI_API_KEY=
# AI_SYSTEM_OPENAI_MODEL=gpt-4o-mini
# AI_SYSTEM_GOOGLE_API_KEY=
# AI_SYSTEM_GOOGLE_MODEL=gemini-1.5-flash
# AI_SYSTEM_QWEN_API_KEY=
# AI_SYSTEM_QWEN_MODEL=qwen-plus
#
# Optional provider base URLs
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

DB_HOST=localhost
DB_PORT=5432
DB_NAME=veridis_finance
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000

# Seed defaults
SEED_ORG_NAME="642 Studio"
SEED_ORG_SLUG=642-studio
SEED_ORG_PLAN=free
SEED_ADMIN_EMAIL=admin@642studio.com
SEED_ADMIN_NAME="642 Studio Owner"
SEED_ADMIN_PASSWORD=ChangeMe123!
# Optional plain API key to seed in finance.api_keys
# SEED_API_KEY=
# Optional: pre-hashed password, overrides SEED_ADMIN_PASSWORD
# SEED_ADMIN_PASSWORD_HASH=

# Optional alternative to DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/veridis_finance
